GMAIL_QUERY='subject:"application received" OR subject:"thank you for applying" OR subject:"offer letter"'
POLL_INTERVAL_MINUTES=15
SHEET_NAME="Job Application Tracker"
LOG_LEVEL=INFO

# ── Shared notification gateways (set up once by the app owner) ──

# Telegram: create a bot via @BotFather, paste the token here.
# Reviewers will DM this bot to connect — they only enter their @username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=OfferTrackerBot

# Slack: create a Slack app with users:read.email + chat:write + users:read,
# install to your workspace, paste the Bot User OAuth Token here.
# Reviewers only enter their work email.
SLACK_BOT_TOKEN=

# WhatsApp (CallMeBot): register your OWN phone at callmebot.com,
# paste the API key here. Reviewers just enter their phone number
# and do a one-time activation (send "I allow CallMeBot" to the gateway).
WHATSAPP_APIKEY=

# Optional: Pushover fallback (fast — $5 one-time for the app)
# ── AI / LLM Provider (FREE options) ──
# Set AI_PROVIDER to "gemini", "groq", or "nvidia" to enable AI parsing.
# Set to "none" (default) to use regex-only.
AI_PROVIDER=none
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
# Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768
# NVIDIA models: meta/llama-3.1-70b-instruct, mistralai/mixtral-8x22b-instruct-v0.1

PUSHOVER_TOKEN=
PUSHOVER_USER=
